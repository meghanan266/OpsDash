{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=OpsDash;Trusted_Connection=true;TrustServerCertificate=true"
  },
  "JwtSettings": {
    "Key": "OVERRIDE-THIS-IN-PRODUCTION-WITH-A-SECURE-64-CHAR-KEY-12345678",
    "Issuer": "https://localhost:5001",
    "Audience": "https://localhost:4200",
    "ExpirationMinutes": 60
  },
  "CorsOrigins": [ "http://localhost:4200" ],
  "Forecasting": {
    "DefaultDataPoints": 30,
    "ForecastHorizon": 7,
    "DefaultMethod": "WMA"
  },
  "AnomalyDetection": {
    "BaselineDataPoints": 30,
    "ZScoreThreshold": 2.0,
    "WarningSeverityMin": 2.0,
    "CriticalSeverityMin": 2.5,
    "SevereSeverityMin": 3.0,
    "CorrelationWindowMinutes": 15,
    "CorrelationZScoreThreshold": 1.5,
    "IncidentGroupingWindowMinutes": 30
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
